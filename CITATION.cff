cff-version: 1.2.0
title: "RUIN: An Automated Framework for Assessing Intellectual Integrity and Reproducibility in Computer Science Publications"
message: "If you use this framework or dataset, please cite the accompanying paper and this repository."
type: software
authors:
  - family-names: Bocan
    given-names: Valer
    orcid: "https://orcid.org/0009-0006-9084-4064"
    affiliation: "Politehnica University of Timișoara, Romania"
  - family-names: Bălaș
    given-names: Valentina E.
